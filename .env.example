# Copy to .env and fill in. Never commit the resulting .env.
# Secret handling policy: docs/adr/0008-secrets-env-vars.md

# --- Application ---
APP_ENV=dev
APP_BASE_URL=http://localhost:5173
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Database ---
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ta_report

# Three-role DB connections (ADR 0010 — audit log grants, NFR-PRIV-4/5).
# Point each URL at a Postgres role with the specific grants from backend/grants.sql.
# In dev/test these may be left empty (falls back to DATABASE_URL; grants not enforced).
# In prod both MUST be set to distinct restricted-role DSNs or the app refuses to start.
DATABASE_URL_ERASURE=
DATABASE_URL_SWEEP=

# --- Session ---
# 64+ random chars. Rotate every 90 days. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SESSION_SECRET_KEY=
SESSION_IDLE_TIMEOUT_MINUTES=240
SESSION_ABSOLUTE_TIMEOUT_MINUTES=1440

# --- Google Workspace SSO (ADR 0004) ---
# Only users on this Google Workspace domain may log in.
ALLOWED_HD=symphony.is
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/callback

# --- Google Sheets service account (ADR 0003) ---
# Path to the service account JSON inside the container / host.
# Rotate the key every 180 days.
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=./secrets/service_account.json
SPREADSHEET_ID=
SPREADSHEET_TAB_NAME=Report Template

# --- Vite dev-server proxy ---
# In Docker dev the proxy must target the backend service by name.
# Override to http://backend:8000 when running inside docker-compose.
VITE_API_PROXY_TARGET=http://localhost:8000
