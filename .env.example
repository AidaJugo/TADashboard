# Copy to .env and fill in. Never commit the resulting .env.
# Secret handling policy: docs/adr/0008-secrets-env-vars.md

# --- Application ---
APP_ENV=dev
APP_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Database ---
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ta_report

# --- Session ---
# 64+ random chars. Rotate every 90 days. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SESSION_SECRET_KEY=
SESSION_IDLE_TIMEOUT_MINUTES=240
SESSION_ABSOLUTE_TIMEOUT_MINUTES=1440

# --- Google Workspace SSO (ADR 0004) ---
# Only users on this Google Workspace domain may log in.
ALLOWED_HD=symphony.is
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback

# --- Google Sheets service account (ADR 0003) ---
# Path to the service account JSON inside the container / host.
# Rotate the key every 180 days.
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=./secrets/service_account.json
SPREADSHEET_ID=
SPREADSHEET_TAB_NAME=Report Template
